{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Brosdk Demo",
  "identifier": "com.brosdk.demo",
  "version": "1.0.2",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Brosdk SDK Demo",
        "width": 620,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^https?://.+"
    }
  }
}
