{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Brosdk Demo",
  "identifier": "com.brosdk.demo",
  "version": "1.0.2",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Brosdk SDK Demo",
        "width": 1080,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "targets": "all",
    "category": "DeveloperTools",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "resources": {},
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "exceptionDomain": null,
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^https?://.+"
    }
  }
}
